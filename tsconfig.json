{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": false,

    "allowJs": true,
    "checkJs": false,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "types": ["node"],

    "noEmit": true
  },

  "exclude": [
    "node_modules"
  ]
}